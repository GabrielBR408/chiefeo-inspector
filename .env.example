# ChiefEO Inspector — environment
#
# ── AI report drafting ──────────────────────────────────────────────────────
# AI report drafting calls the Anthropic API from the Vercel serverless
# function api/draft.js. Set this in the Vercel project (Settings → Environment
# Variables). When unset, the app still works — it produces a deterministic,
# count-based summary instead of an AI-written one.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional account layer (Phase 2 auth) ───────────────────────────────────
# Powers the signup nudge / account menu / referral capture only. There is NO
# gating: anonymous users keep 100% of the app. All three are safe to expose in
# the client bundle (VITE_* are inlined at build time). Use the anon /
# publishable key ONLY — NEVER the service_role key. Inspection photos, notes,
# and drafted content NEVER touch Supabase; auth state is the only thing that does.
#
# Set these in the Vercel project for both the proxied (chiefeotool.com) and the
# direct (chiefeo-inspector.vercel.app) deployments. When unset, the account UI
# silently disappears and the app runs exactly as before.
VITE_SUPABASE_URL=https://dsmbppzvembacitwdrsj.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_SITE_URL=https://chiefeotool.com
